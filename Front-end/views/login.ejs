<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gaming Hub | Login & Register</title>
    <meta name="description" content="Sign in or create an account to access Gaming Hub's marketplace, wallet, and exclusive gaming products.">
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: #050505;
            color: #fff;
            font-family: 'Inter', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ─── Animated Background ─── */
        .auth-bg {
            position: fixed;
            inset: 0;
            z-index: 0;
            background:
                radial-gradient(ellipse at 20% 50%, rgba(109, 40, 217, 0.15) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 20%, rgba(0, 245, 255, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 80%, rgba(237, 255, 102, 0.05) 0%, transparent 50%),
                #050505;
        }

        .auth-bg::before {
            content: '';
            position: absolute;
            inset: 0;
            background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><defs><pattern id="g" width="20" height="20" patternUnits="userSpaceOnUse"><circle cx="1" cy="1" r="0.5" fill="rgba(255,255,255,0.03)"/></pattern></defs><rect fill="url(%23g)" width="100" height="100"/></svg>');
            opacity: 0.5;
        }

        /* ─── Auth Container ─── */
        .auth-wrapper {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            align-items: center;
            justify-content: center;
            padding: 80px 20px 40px;
        }

        .auth-logo {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 32px;
            text-decoration: none;
            cursor: pointer;
        }

        .auth-logo img {
            width: 48px;
            height: 48px;
        }

        .auth-logo span {
            font-size: 24px;
            font-weight: 800;
            background: linear-gradient(135deg, #edff66, #00f5ff);
            background-clip: text;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 1px;
        }

        /* ─── Glass Card ─── */
        .auth-card {
            width: 100%;
            max-width: 460px;
            background: rgba(15, 15, 25, 0.85);
            backdrop-filter: blur(24px);
            border: 1px solid rgba(109, 40, 217, 0.25);
            border-radius: 24px;
            padding: 40px;
            position: relative;
            overflow: hidden;
            box-shadow:
                0 32px 64px rgba(0, 0, 0, 0.5),
                0 0 80px rgba(109, 40, 217, 0.08);
        }

        .auth-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #6d28d9, #00f5ff, #edff66, #6d28d9);
            background-size: 200% auto;
            animation: gradient-shift 3s linear infinite;
        }

        @keyframes gradient-shift {
            to { background-position: 200% center; }
        }

        /* ─── Tab Switcher ─── */
        .auth-tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 32px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 14px;
            padding: 4px;
        }

        .auth-tab {
            flex: 1;
            padding: 12px;
            text-align: center;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            border-radius: 10px;
            transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            color: #94a3b8;
            border: none;
            background: transparent;
        }

        .auth-tab.active {
            background: linear-gradient(135deg, #6d28d9, #7c3aed);
            color: #fff;
            box-shadow: 0 4px 15px rgba(109, 40, 217, 0.4);
        }

        .auth-tab:hover:not(.active) {
            color: #cbd5e1;
            background: rgba(255, 255, 255, 0.05);
        }

        /* ─── Form Styles ─── */
        .auth-form { display: none; }
        .auth-form.active { display: block; animation: fadeSlideIn 0.4s ease; }

        @keyframes fadeSlideIn {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .form-heading {
            font-size: 26px;
            font-weight: 700;
            margin-bottom: 6px;
        }

        .form-subtext {
            color: #94a3b8;
            font-size: 14px;
            margin-bottom: 28px;
        }

        .input-group {
            margin-bottom: 20px;
            position: relative;
        }

        .input-group label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #a78bfa;
            margin-bottom: 8px;
        }

        .input-group .input-wrap {
            position: relative;
        }

        .input-group .input-wrap i {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #6d28d9;
            font-size: 14px;
        }

        .input-group input {
            width: 100%;
            padding: 14px 16px 14px 44px;
            background: #0c0c18;
            border: 1px solid #1e1e3a;
            border-radius: 12px;
            color: #fff;
            font-size: 15px;
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
            outline: none;
        }

        .input-group input:focus {
            border-color: #6d28d9;
            box-shadow: 0 0 0 3px rgba(109, 40, 217, 0.15), 0 0 20px rgba(109, 40, 217, 0.1);
        }

        .input-group input::placeholder {
            color: #4a4a6a;
        }

        /* ─── Submit Button ─── */
        .auth-submit {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 14px;
            font-size: 15px;
            font-weight: 700;
            font-family: 'Inter', sans-serif;
            letter-spacing: 1px;
            text-transform: uppercase;
            cursor: pointer;
            margin-top: 8px;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
            background: linear-gradient(135deg, #6d28d9, #7c3aed);
            color: #fff;
            box-shadow: 0 4px 20px rgba(109, 40, 217, 0.4);
        }

        .auth-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(109, 40, 217, 0.6);
        }

        .auth-submit:active {
            transform: translateY(0);
        }

        .auth-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        /* ─── Messages ─── */
        .auth-message {
            padding: 12px 16px;
            border-radius: 10px;
            font-size: 13px;
            font-weight: 500;
            margin-bottom: 20px;
            display: none;
            align-items: center;
            gap: 8px;
            animation: fadeSlideIn 0.3s ease;
        }

        .auth-message.error {
            display: flex;
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #fca5a5;
        }

        .auth-message.success {
            display: flex;
            background: rgba(34, 197, 94, 0.1);
            border: 1px solid rgba(34, 197, 94, 0.3);
            color: #86efac;
        }

        /* ─── Divider ─── */
        .auth-divider {
            display: flex;
            align-items: center;
            gap: 16px;
            margin: 24px 0;
            color: #4a4a6a;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .auth-divider::before, .auth-divider::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(to right, transparent, #2a2a4a, transparent);
        }

        /* ─── Wallet Badge ─── */
        .wallet-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 18px;
            background: linear-gradient(135deg, rgba(237, 255, 102, 0.05), rgba(0, 245, 255, 0.05));
            border: 1px solid rgba(237, 255, 102, 0.15);
            border-radius: 12px;
            margin-bottom: 24px;
        }

        .wallet-badge i {
            color: #edff66;
            font-size: 20px;
        }

        .wallet-badge span {
            color: #cbd5e1;
            font-size: 13px;
        }

        .wallet-badge strong {
            color: #edff66;
        }

        /* ─── Responsive ─── */
        @media (max-width: 520px) {
            .auth-card {
                padding: 28px 20px;
                border-radius: 18px;
            }

            .form-heading { font-size: 22px; }
        }
    </style>
</head>

<body>
    <header>
        <div class="head-left">
            <img src="images/logo.png" alt="logo">
            <button onclick="window.location.href='/store'">Products</button>
        </div>
        <div class="head-right">
            <p><a href="/">HOME</a></p>
            <p><a href="/#about">ABOUT</a></p>
            <p><a href="/store">STORE</a></p>
            <p><a href="/faqs">FAQS</a></p>
            <p><a href="/contact">CONTACT</a></p>
        </div>
    </header>

    <div class="auth-bg"></div>

    <div class="auth-wrapper">
        <a class="auth-logo" href="/">
            <img src="images/logo.png" alt="Gaming Hub">
            <span>GAMING HUB</span>
        </a>

        <div class="auth-card">
            <!-- Tab Switcher -->
            <div class="auth-tabs">
                <button class="auth-tab active" id="tab-login" onclick="switchTab('login')">Sign In</button>
                <button class="auth-tab" id="tab-register" onclick="switchTab('register')">Sign Up</button>
            </div>

            <!-- Message Area -->
            <div class="auth-message" id="auth-message"></div>

            <!-- LOGIN FORM -->
            <form class="auth-form active" id="login-form" onsubmit="handleLogin(event)">
                <h2 class="form-heading">Welcome Back</h2>
                <p class="form-subtext">Enter your credentials to access your account</p>

                <div class="input-group">
                    <label for="login-email">Email</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="login-email" placeholder="you@example.com" required>
                    </div>
                </div>

                <div class="input-group">
                    <label for="login-password">Password</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="login-password" placeholder="••••••••" required minlength="6">
                    </div>
                </div>

                <button type="submit" class="auth-submit" id="login-btn">
                    <i class="fas fa-bolt"></i> Sign In
                </button>
            </form>

            <!-- REGISTER FORM -->
            <form class="auth-form" id="register-form" onsubmit="handleRegister(event)">
                <h2 class="form-heading">Create Account</h2>
                <p class="form-subtext">Join the community and start your journey</p>

                <div class="wallet-badge">
                    <i class="fas fa-coins"></i>
                    <span>New players receive <strong>$1,000</strong> wallet bonus!</span>
                </div>

                <div class="input-group">
                    <label for="reg-username">Username</label>
                    <div class="input-wrap">
                        <i class="fas fa-user"></i>
                        <input type="text" id="reg-username" placeholder="Choose a gamer tag" required minlength="3">
                    </div>
                </div>

                <div class="input-group">
                    <label for="reg-email">Email</label>
                    <div class="input-wrap">
                        <i class="fas fa-envelope"></i>
                        <input type="email" id="reg-email" placeholder="you@example.com" required>
                    </div>
                </div>

                <div class="input-group">
                    <label for="reg-password">Password</label>
                    <div class="input-wrap">
                        <i class="fas fa-lock"></i>
                        <input type="password" id="reg-password" placeholder="Min 6 characters" required minlength="6">
                    </div>
                </div>

                <button type="submit" class="auth-submit" id="register-btn">
                    <i class="fas fa-rocket"></i> Create Account
                </button>
            </form>

            <div class="auth-divider">or</div>
            <p style="text-align: center; color: #94a3b8; font-size: 13px;">
                <a href="/" style="color: #a78bfa; text-decoration: none;">← Back to Home</a>
            </p>
        </div>
    </div>

    <script>
        const API_BASE = window.location.origin;

        // On Page Load: Check for activation parameters
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.get('activated') === 'true') {
                showMessage('Account activated successfully! You can now log in.', 'success');
                switchTab('login');
            } else if (urlParams.get('activated') === 'already') {
                showMessage('Account already activated! Please log in.', 'success');
                switchTab('login');
            }
        });

        // Tab switching
        function switchTab(tab) {
            document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.auth-form').forEach(f => f.classList.remove('active'));

            document.getElementById(`tab-${tab}`).classList.add('active');
            document.getElementById(`${tab}-form`).classList.add('active');
            hideMessage();
        }

        // Messages
        function showMessage(text, type = 'error') {
            const msg = document.getElementById('auth-message');
            msg.style.display = 'block';
            msg.className = `auth-message ${type}`;
            msg.innerHTML = `<i class="fas fa-${type === 'error' ? 'exclamation-circle' : 'check-circle'}"></i> ${text}`;
        }

        function hideMessage() {
            const msg = document.getElementById('auth-message');
            msg.className = 'auth-message';
            msg.style.display = 'none';
        }

        // Login handler
        async function handleLogin(e) {
            e.preventDefault();
            const btn = document.getElementById('login-btn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Signing In...';

            try {
                const res = await fetch(`${API_BASE}/api/auth/login`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email: document.getElementById('login-email').value,
                        password: document.getElementById('login-password').value,
                    }),
                });

                const data = await res.json();

                if (!res.ok) throw new Error(data.message);

                // Save to localStorage
                localStorage.setItem('token', data.token);
                localStorage.setItem('user', JSON.stringify({
                    _id: data._id,
                    username: data.username,
                    email: data.email,
                    role: data.role,
                    walletBalance: data.walletBalance,
                }));

                showMessage('Login successful! Redirecting...', 'success');
                setTimeout(() => window.location.href = '/', 1000);
            } catch (err) {
                showMessage(err.message || 'Login failed');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-bolt"></i> Sign In';
            }
        }

        // Register handler
        async function handleRegister(e) {
            e.preventDefault();
            const btn = document.getElementById('register-btn');
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Creating Account...';

            try {
                const res = await fetch(`${API_BASE}/api/auth/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        username: document.getElementById('reg-username').value,
                        email: document.getElementById('reg-email').value,
                        password: document.getElementById('reg-password').value,
                    }),
                });

                const data = await res.json();

                if (!res.ok) throw new Error(data.message);

                showMessage(data.message || 'Account created! Please check your email to activate.', 'success');
                
                // Clear fields
                document.getElementById('reg-username').value = '';
                document.getElementById('reg-email').value = '';
                document.getElementById('reg-password').value = '';
                
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-rocket"></i> Create Account';

                // Automatically switch to login tab after a few seconds
                setTimeout(() => switchTab('login'), 4000);
            } catch (err) {
                showMessage(err.message || 'Registration failed');
                btn.disabled = false;
                btn.innerHTML = '<i class="fas fa-rocket"></i> Create Account';
            }
        }

        // If already logged in, redirect
        if (localStorage.getItem('token') && !window.location.search.includes('activated')) {
            window.location.href = '/';
        }
    </script>
</body>

</html>
