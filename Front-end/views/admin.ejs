<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gaming Hub | Admin Dashboard</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
        body {
            background: #050505;
            color: #fff;
            font-family: 'Inter', sans-serif;
            margin: 0;
            overflow-x: hidden;
        }

        .admin-container {
            max-width: 1400px;
            margin: 90px auto 60px;
            padding: 0 20px;
            display: grid;
            grid-template-columns: 240px 1fr;
            gap: 30px;
            animation: fadeIn 0.6s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(15px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* ─── Sidebar ─── */
        .admin-sidebar {
            background: rgba(15, 15, 25, 0.85);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(109, 40, 217, 0.2);
            border-radius: 18px;
            padding: 24px 16px;
            height: fit-content;
        }

        .admin-sidebar h3 {
            font-size: 14px;
            font-weight: 800;
            text-transform: uppercase;
            color: #a78bfa;
            letter-spacing: 2px;
            margin: 0 0 20px 10px;
        }

        .sidebar-menu {
            display: flex;
            flex-direction: column;
            gap: 8px;
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .menu-item button {
            width: 100%;
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            background: transparent;
            border: none;
            color: #cbd5e1;
            font-size: 14px;
            font-weight: 600;
            text-align: left;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
        }

        .menu-item button:hover {
            color: #fff;
            background: rgba(109, 40, 217, 0.15);
        }

        .menu-item.active button {
            color: #000;
            background: linear-gradient(135deg, #6d28d9, #00f5ff);
            font-weight: 800;
        }

        /* ─── Main Panel Content ─── */
        .admin-main {
            display: flex;
            flex-direction: column;
            gap: 30px;
        }

        .admin-card {
            background: rgba(15, 15, 25, 0.85);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(109, 40, 217, 0.2);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
        }

        .admin-card h2 {
            font-size: 20px;
            margin: 0 0 24px 0;
            display: flex;
            align-items: center;
            gap: 10px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding-bottom: 16px;
            color: #00f5ff;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* ─── Analytics Summary ─── */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-box {
            background: rgba(15, 15, 25, 0.85);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(109, 40, 217, 0.2);
            border-radius: 18px;
            padding: 24px;
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .stat-icon {
            width: 54px;
            height: 54px;
            border-radius: 12px;
            background: rgba(109, 40, 217, 0.15);
            color: #a78bfa;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            border: 1px solid rgba(109, 40, 217, 0.3);
        }

        .stat-box.sales .stat-icon {
            background: rgba(34, 197, 94, 0.15);
            color: #22c55e;
            border-color: rgba(34, 197, 94, 0.3);
        }

        .stat-details h4 {
            margin: 0;
            font-size: 13px;
            color: #94a3b8;
            text-transform: uppercase;
        }

        .stat-details p {
            margin: 4px 0 0 0;
            font-size: 26px;
            font-weight: 800;
            color: #fff;
        }

        /* ─── Tables ─── */
        .table-responsive {
            overflow-x: auto;
            margin-top: 15px;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
            font-size: 14px;
        }

        .admin-table th {
            padding: 14px 16px;
            background: #0c0c18;
            color: #a78bfa;
            font-weight: 700;
            border-bottom: 2px solid #1e1e3a;
        }

        .admin-table td {
            padding: 14px 16px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            color: #cbd5e1;
            vertical-align: middle;
        }

        .admin-table tr:hover td {
            background: rgba(255, 255, 255, 0.02);
            color: #fff;
        }

        /* Inputs inside table */
        .admin-table input,
        .admin-table select {
            background: #05050a;
            border: 1px solid #1e1e3a;
            border-radius: 8px;
            color: #fff;
            padding: 6px 10px;
            font-size: 13px;
            font-family: 'Inter', sans-serif;
            outline: none;
        }

        .admin-table input[type="number"] {
            width: 90px;
        }

        /* Buttons & Badges */
        .btn-action {
            padding: 6px 12px;
            border: 1px solid #1e1e3a;
            border-radius: 8px;
            background: transparent;
            color: #94a3b8;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 12px;
            font-family: 'Inter', sans-serif;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-action.save:hover {
            border-color: #22c55e;
            color: #22c55e;
            background: rgba(34, 197, 94, 0.08);
        }

        .btn-action.delete:hover {
            border-color: #ef4444;
            color: #ef4444;
            background: rgba(239, 68, 68, 0.08);
        }

        .status-badge {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-badge.pending { background: rgba(234, 179, 8, 0.15); color: #eab308; }
        .status-badge.shipped { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }
        .status-badge.delivered { background: rgba(34, 197, 94, 0.15); color: #22c55e; }
        .status-badge.cancelled { background: rgba(239, 68, 68, 0.15); color: #ef4444; }

        /* ─── Product Form ─── */
        .product-form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 20px;
            margin-bottom: 24px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group label {
            font-size: 12px;
            font-weight: 600;
            color: #94a3b8;
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            padding: 12px 14px;
            background: #0c0c18;
            border: 1px solid #1e1e3a;
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            outline: none;
            transition: border-color 0.3s;
        }

        .form-group textarea {
            min-height: 80px;
            resize: vertical;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: #6d28d9;
        }

        .btn-submit {
            padding: 12px 24px;
            background: linear-gradient(135deg, #6d28d9, #00f5ff);
            border: none;
            border-radius: 10px;
            color: #000;
            font-size: 14px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s;
            font-family: 'Inter', sans-serif;
            text-transform: uppercase;
        }

        .btn-submit:hover {
            box-shadow: 0 0 15px rgba(0, 245, 255, 0.4);
            transform: translateY(-1px);
        }

        .product-list-compact {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 20px;
        }

        .compact-card {
            background: #0c0c18;
            border: 1px solid #1e1e3a;
            border-radius: 12px;
            padding: 16px;
            display: flex;
            gap: 12px;
            align-items: center;
        }

        .compact-card img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
            background: #050505;
        }

        .compact-details {
            flex: 1;
            min-width: 0;
        }

        .compact-details h5 {
            margin: 0;
            font-size: 14px;
            font-weight: 700;
            color: #fff;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .compact-details p {
            margin: 4px 0 0 0;
            font-size: 12px;
            color: #94a3b8;
        }

        .compact-actions {
            display: flex;
            flex-direction: column;
            gap: 6px;
        }

        /* Responsive */
        @media (max-width: 900px) {
            .admin-container {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body>
    <header>
        <div class="head-left">
            <img src="images/logo.png" alt="logo">
            <button onclick="window.location.href='/store'">Products</button>
        </div>
        <div class="head-right">
            <p><a href="/">HOME</a></p>
            <p><a href="/#about">ABOUT</a></p>
            <p><a href="/store">STORE</a></p>
            <p><a href="/faqs">FAQS</a></p>
            <p><a href="/contact">CONTACT</a></p>
            <p id="nav-auth-link"></p>
        </div>
    </header>

    <div class="admin-container">
        <!-- Sidebar Navigation -->
        <aside class="admin-sidebar">
            <h3>Control Panel</h3>
            <ul class="sidebar-menu">
                <li class="menu-item active" id="tab-btn-dash"><button onclick="switchTab('dash')"><i class="fas fa-chart-line"></i> Dashboard</button></li>
                <li class="menu-item" id="tab-btn-users"><button onclick="switchTab('users')"><i class="fas fa-users"></i> User Accounts</button></li>
                <li class="menu-item" id="tab-btn-products"><button onclick="switchTab('products')"><i class="fas fa-cubes"></i> Product Inventory</button></li>
                <li class="menu-item" id="tab-btn-orders"><button onclick="switchTab('orders')"><i class="fas fa-shopping-basket"></i> Customer Orders</button></li>
            </ul>
        </aside>

        <!-- Main Panel Content -->
        <main class="admin-main">
            <!-- 1. DASHBOARD VIEW -->
            <div class="admin-view active" id="view-dash">
                <div class="dashboard-grid">
                    <div class="stat-box">
                        <div class="stat-icon"><i class="fas fa-users"></i></div>
                        <div class="stat-details">
                            <h4>Total Users</h4>
                            <p id="stat-users">0</p>
                        </div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-icon"><i class="fas fa-cubes"></i></div>
                        <div class="stat-details">
                            <h4>Active Items</h4>
                            <p id="stat-products">0</p>
                        </div>
                    </div>
                    <div class="stat-box">
                        <div class="stat-icon"><i class="fas fa-shopping-basket"></i></div>
                        <div class="stat-details">
                            <h4>Total Orders</h4>
                            <p id="stat-orders">0</p>
                        </div>
                    </div>
                    <div class="stat-box sales">
                        <div class="stat-icon"><i class="fas fa-coins"></i></div>
                        <div class="stat-details">
                            <h4>Gross Revenue</h4>
                            <p id="stat-revenue">$0.00</p>
                        </div>
                    </div>
                </div>

                <div class="admin-card">
                    <h2><i class="fas fa-bolt"></i> Quick Overview</h2>
                    <p style="color: #cbd5e1; line-height: 1.6; margin: 0;">
                        Welcome back to the Admin Dashboard. Select an option from the sidebar to manage users, update the store catalog, or review and ship pending customer orders. All adjustments propagate live to user clients.
                    </p>
                </div>
            </div>

            <!-- 2. USER ACCOUNTS CRUD VIEW -->
            <div class="admin-view" id="view-users" style="display:none;">
                <div class="admin-card">
                    <h2><i class="fas fa-users"></i> User Accounts Management</h2>
                    <div class="table-responsive">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Username</th>
                                    <th>Email Address</th>
                                    <th>Verified</th>
                                    <th>Role</th>
                                    <th>Wallet Balance ($)</th>
                                    <th style="text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="user-table-body">
                                <tr>
                                    <td colspan="6" style="text-align: center; padding: 40px;"><i class="fas fa-spinner fa-spin"></i> Fetching users database...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- 3. PRODUCT INVENTORY CRUD VIEW -->
            <div class="admin-view" id="view-products" style="display:none;">
                <!-- Add Product -->
                <div class="admin-card">
                    <h2 id="product-form-title"><i class="fas fa-plus"></i> Create New Catalog Product</h2>
                    <input type="hidden" id="prod-edit-id">
                    <div class="product-form">
                        <div class="form-group">
                            <label>Product Title</label>
                            <input type="text" id="prod-title" placeholder="e.g. Mechanical Gaming Keyboard">
                        </div>
                        <div class="form-group">
                            <label>Price ($)</label>
                            <input type="number" id="prod-price" placeholder="0.00" min="0" step="0.01">
                        </div>
                        <div class="form-group">
                            <label>Category</label>
                            <select id="prod-category">
                                <option value="Peripherals">Peripherals</option>
                                <option value="Hardware">Hardware</option>
                                <option value="Displays">Displays</option>
                                <option value="Audio">Audio</option>
                                <option value="Consoles">Consoles</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Image URL</label>
                            <input type="text" id="prod-image" placeholder="https://unsplash.com/...">
                        </div>
                        <div class="form-group" style="grid-column: 1 / -1;">
                            <label>Description</label>
                            <textarea id="prod-desc" placeholder="Detail hardware specifications and key benefits..."></textarea>
                        </div>
                    </div>
                    <div style="display:flex; gap: 10px;">
                        <button class="btn-submit" id="btn-prod-save" onclick="saveProduct()">Create Product</button>
                        <button class="btn-action" id="btn-prod-cancel" onclick="resetProductForm()" style="display:none; padding:12px 24px;">Cancel</button>
                    </div>
                </div>

                <!-- Existing Products List -->
                <div class="admin-card">
                    <h2><i class="fas fa-list"></i> Current Store Inventory</h2>
                    <div class="product-list-compact" id="compact-products-list">
                        <div style="grid-column: 1/-1; text-align: center; padding: 40px;"><i class="fas fa-spinner fa-spin"></i> Fetching products...</div>
                    </div>
                </div>
            </div>

            <!-- 4. CUSTOMER ORDERS CRUD VIEW -->
            <div class="admin-view" id="view-orders" style="display:none;">
                <div class="admin-card">
                    <h2><i class="fas fa-shopping-basket"></i> Customer Orders & Deliveries</h2>
                    <div class="table-responsive">
                        <table class="admin-table">
                            <thead>
                                <tr>
                                    <th>Order ID</th>
                                    <th>Buyer</th>
                                    <th>Date Placed</th>
                                    <th>Purchased Items</th>
                                    <th>Total Charged</th>
                                    <th>Payment</th>
                                    <th>Status</th>
                                    <th style="text-align: right;">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="orders-table-body">
                                <tr>
                                    <td colspan="8" style="text-align: center; padding: 40px;"><i class="fas fa-spinner fa-spin"></i> Fetching client transactions...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toast-container"></div>

    <script>
        const API_BASE = window.location.origin;
        const token = localStorage.getItem('token');
        const user = JSON.parse(localStorage.getItem('user') || 'null');

        // Security check: Guard page
        if (!user || user.role !== 'admin') {
            alert('Access Denied. Admin authentication required.');
            window.location.href = '/';
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateNavAuth();
            loadDashboardStats();
        });

        function updateNavAuth() {
            const authLink = document.getElementById('nav-auth-link');
            if (authLink && user) {
                authLink.innerHTML = `<a href="#" onclick="logout()" style="color:#edff66;">${user.username} (Logout)</a>`;
            }
        }

        function logout() {
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            window.location.href = '/';
        }

        // Tab Switcher
        function switchTab(tab) {
            document.querySelectorAll('.menu-item').forEach(el => el.classList.remove('active'));
            document.querySelectorAll('.admin-view').forEach(el => el.style.display = 'none');

            document.getElementById(`tab-btn-${tab}`).classList.add('active');
            document.getElementById(`view-${tab}`).style.display = 'block';

            if (tab === 'dash') loadDashboardStats();
            if (tab === 'users') loadUsers();
            if (tab === 'products') {
                loadProducts();
                resetProductForm();
            }
            if (tab === 'orders') loadOrders();
        }

        // ─── Analytics ───
        async function loadDashboardStats() {
            try {
                // Fetch users
                const resUsers = await fetch(`${API_BASE}/api/auth/users`, { headers: { 'Authorization': `Bearer ${token}` } });
                const users = await resUsers.json();
                
                // Fetch products (get limit 100 to get total count easily)
                const resProds = await fetch(`${API_BASE}/api/products?limit=100`);
                const prodsData = await resProds.json();
                
                // Fetch orders
                const resOrders = await fetch(`${API_BASE}/api/orders`, { headers: { 'Authorization': `Bearer ${token}` } });
                const orders = await resOrders.json();

                document.getElementById('stat-users').textContent = users.length;
                document.getElementById('stat-products').textContent = prodsData.total || prodsData.products?.length || 0;
                document.getElementById('stat-orders').textContent = orders.length;

                // Revenue calculation (sum delivered and shipped orders)
                let revenue = 0;
                orders.forEach(o => {
                    if (o.status !== 'Cancelled') {
                        revenue += o.total;
                    }
                });
                document.getElementById('stat-revenue').textContent = `$${revenue.toFixed(2)}`;
            } catch (err) {
                console.error('Stats error:', err);
            }
        }

        // ─── Users Tab CRUD ───
        async function loadUsers() {
            const tbody = document.getElementById('user-table-body');
            tbody.innerHTML = `<tr><td colspan="6" style="text-align: center; padding: 40px;"><i class="fas fa-spinner fa-spin"></i> Loading users...</td></tr>`;
            try {
                const res = await fetch(`${API_BASE}/api/auth/users`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const usersList = await res.json();
                
                tbody.innerHTML = usersList.map(u => `
                    <tr id="row-user-${u._id}">
                        <td><strong>${u.username}</strong></td>
                        <td>${u.email}</td>
                        <td>
                            <span style="color: ${u.active ? '#22c55e' : '#ef4444'}">
                                <i class="fas fa-${u.active ? 'check-circle' : 'times-circle'}"></i> ${u.active ? 'Yes' : 'No'}
                            </span>
                        </td>
                        <td>
                            <select id="user-role-${u._id}">
                                <option value="user" ${u.role === 'user' ? 'selected' : ''}>User</option>
                                <option value="admin" ${u.role === 'admin' ? 'selected' : ''}>Admin</option>
                            </select>
                        </td>
                        <td>
                            <input type="number" id="user-balance-${u._id}" value="${u.walletBalance}" min="0" step="0.01">
                        </td>
                        <td style="text-align: right;">
                            <button class="btn-action save" onclick="saveUserUpdate('${u._id}')"><i class="fas fa-save"></i> Save</button>
                            <button class="btn-action delete" onclick="deleteUser('${u._id}')" ${u._id === user._id ? 'disabled title="You cannot delete yourself"' : ''}><i class="fas fa-trash"></i> Delete</button>
                        </td>
                    </tr>
                `).join('');
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="6" style="color: #ef4444; text-align: center; padding: 40px;">Failed to load users: ${err.message}</td></tr>`;
            }
        }

        async function saveUserUpdate(id) {
            const role = document.getElementById(`user-role-${id}`).value;
            const walletBalance = document.getElementById(`user-balance-${id}`).value;

            try {
                const res = await fetch(`${API_BASE}/api/auth/users/${id}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ role, walletBalance: Number(walletBalance) })
                });

                const data = await res.json();
                if (!res.ok) throw new Error(data.message);

                showToast('User settings updated successfully!', 'success');
            } catch (err) {
                showToast(err.message, 'error');
            }
        }

        async function deleteUser(id) {
            if (!confirm('Are you sure you want to permanently delete this user account? This cannot be undone.')) return;

            try {
                const res = await fetch(`${API_BASE}/api/auth/users/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                const data = await res.json();
                if (!res.ok) throw new Error(data.message);

                showToast('User account successfully deleted.', 'success');
                document.getElementById(`row-user-${id}`).remove();
            } catch (err) {
                showToast(err.message, 'error');
            }
        }

        // ─── Products Tab CRUD ───
        async function loadProducts() {
            const grid = document.getElementById('compact-products-list');
            grid.innerHTML = `<div style="grid-column: 1/-1; text-align: center; padding: 40px;"><i class="fas fa-spinner fa-spin"></i> Loading inventory...</div>`;
            try {
                // Fetch up to 100 products for complete list
                const res = await fetch(`${API_BASE}/api/products?limit=100`);
                const data = await res.json();
                const list = data.products || data;

                grid.innerHTML = list.map(p => `
                    <div class="compact-card" id="compact-prod-${p._id}">
                        <img src="${p.image}" alt="${p.title}" onerror="this.src='images/images.jfif'">
                        <div class="compact-details">
                            <h5>${p.title}</h5>
                            <p>${p.category} | <strong>$${p.price.toFixed(2)}</strong></p>
                        </div>
                        <div class="compact-actions">
                            <button class="btn-action save" onclick="editProductSetup('${p._id}', ${JSON.stringify(p).replace(/"/g, '&quot;')})"><i class="fas fa-pen"></i> Edit</button>
                            <button class="btn-action delete" onclick="deleteProduct('${p._id}')"><i class="fas fa-trash"></i> Delete</button>
                        </div>
                    </div>
                `).join('');
            } catch (err) {
                grid.innerHTML = `<div style="grid-column: 1/-1; color:#ef4444; text-align: center; padding: 40px;">Failed to load inventory: ${err.message}</div>`;
            }
        }

        function editProductSetup(id, product) {
            document.getElementById('prod-edit-id').value = id;
            document.getElementById('prod-title').value = product.title;
            document.getElementById('prod-price').value = product.price;
            document.getElementById('prod-category').value = product.category;
            document.getElementById('prod-image').value = product.image || '';
            document.getElementById('prod-desc').value = product.description || '';

            document.getElementById('product-form-title').innerHTML = `<i class="fas fa-pen"></i> Edit Product Catalog Details`;
            document.getElementById('btn-prod-save').textContent = 'Save Changes';
            document.getElementById('btn-prod-cancel').style.display = 'inline-block';

            // Scroll to form
            document.getElementById('product-form-title').scrollIntoView({ behavior: 'smooth' });
        }

        function resetProductForm() {
            document.getElementById('prod-edit-id').value = '';
            document.getElementById('prod-title').value = '';
            document.getElementById('prod-price').value = '';
            document.getElementById('prod-category').value = 'Peripherals';
            document.getElementById('prod-image').value = '';
            document.getElementById('prod-desc').value = '';

            document.getElementById('product-form-title').innerHTML = `<i class="fas fa-plus"></i> Create New Catalog Product`;
            document.getElementById('btn-prod-save').textContent = 'Create Product';
            document.getElementById('btn-prod-cancel').style.display = 'none';
        }

        async function saveProduct() {
            const editId = document.getElementById('prod-edit-id').value;
            const title = document.getElementById('prod-title').value.trim();
            const price = document.getElementById('prod-price').value;
            const category = document.getElementById('prod-category').value;
            const image = document.getElementById('prod-image').value.trim();
            const description = document.getElementById('prod-desc').value.trim();

            if (!title || !price) {
                showToast('Product title and price are required', 'info');
                return;
            }

            const body = { title, price: Number(price), category, image, description };
            const method = editId ? 'PUT' : 'POST';
            const endpoint = editId ? `${API_BASE}/api/products/${editId}` : `${API_BASE}/api/products`;

            try {
                const res = await fetch(endpoint, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify(body)
                });

                const data = await res.json();
                if (!res.ok) throw new Error(data.message);

                showToast(editId ? 'Product details updated!' : 'Product added successfully!', 'success');
                resetProductForm();
                loadProducts();
            } catch (err) {
                showToast(err.message, 'error');
            }
        }

        async function deleteProduct(id) {
            if (!confirm('Are you sure you want to remove this product from the inventory catalog?')) return;

            try {
                const res = await fetch(`${API_BASE}/api/products/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                const data = await res.json();
                if (!res.ok) throw new Error(data.message);

                showToast('Product deleted from inventory.', 'success');
                document.getElementById(`compact-prod-${id}`).remove();
            } catch (err) {
                showToast(err.message, 'error');
            }
        }

        // ─── Orders Tab CRUD ───
        async function loadOrders() {
            const tbody = document.getElementById('orders-table-body');
            tbody.innerHTML = `<tr><td colspan="8" style="text-align: center; padding: 40px;"><i class="fas fa-spinner fa-spin"></i> Loading transactions database...</td></tr>`;
            try {
                const res = await fetch(`${API_BASE}/api/orders`, {
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                const orders = await res.json();

                tbody.innerHTML = orders.map(o => {
                    const formattedDate = new Date(o.createdAt).toLocaleDateString('en-US', {
                        month: 'short', day: 'numeric', year: 'numeric', hour: '2-digit', minute: '2-digit'
                    });

                    const itemsSummary = o.items.map(item => `• ${item.title} (${item.quantity})`).join('<br>');

                    return `
                        <tr id="row-order-${o._id}">
                            <td><strong>${o.orderId}</strong></td>
                            <td>${o.username}</td>
                            <td><span style="font-size:12px; color:#94a3b8;">${formattedDate}</span></td>
                            <td style="max-width:220px; font-size:12px; line-height:1.4;">${itemsSummary}</td>
                            <td><strong style="color: #edff66;">$${o.total.toFixed(2)}</strong></td>
                            <td><span style="text-transform:uppercase; font-size:12px;">${o.paymentMethod}</span></td>
                            <td>
                                <select id="order-status-${o._id}" onchange="changeOrderStatus('${o._id}', this.value)" class="status-select">
                                    <option value="Pending" ${o.status === 'Pending' ? 'selected' : ''}>Pending</option>
                                    <option value="Shipped" ${o.status === 'Shipped' ? 'selected' : ''}>Shipped</option>
                                    <option value="Delivered" ${o.status === 'Delivered' ? 'selected' : ''}>Delivered</option>
                                    <option value="Cancelled" ${o.status === 'Cancelled' ? 'selected' : ''}>Cancelled</option>
                                </select>
                            </td>
                            <td style="text-align: right;">
                                <button class="btn-action delete" onclick="deleteOrder('${o._id}')"><i class="fas fa-trash-alt"></i> Delete</button>
                            </td>
                        </tr>
                    `;
                }).join('');
            } catch (err) {
                tbody.innerHTML = `<tr><td colspan="8" style="color:#ef4444; text-align: center; padding: 40px;">Failed to load transactions: ${err.message}</td></tr>`;
            }
        }

        async function changeOrderStatus(id, status) {
            try {
                const res = await fetch(`${API_BASE}/api/orders/${id}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': `Bearer ${token}`
                    },
                    body: JSON.stringify({ status })
                });

                const data = await res.json();
                if (!res.ok) throw new Error(data.message);

                showToast(`Order status updated to "${status}"!`, 'success');
            } catch (err) {
                showToast(err.message, 'error');
            }
        }

        async function deleteOrder(id) {
            if (!confirm('Are you sure you want to permanently delete/cancel this customer order?')) return;

            try {
                const res = await fetch(`${API_BASE}/api/orders/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}` }
                });

                const data = await res.json();
                if (!res.ok) throw new Error(data.message);

                showToast('Order records removed successfully.', 'success');
                document.getElementById(`row-order-${id}`).remove();
            } catch (err) {
                showToast(err.message, 'error');
            }
        }

        // ─── Toast helper ───
        function showToast(message, type = 'info') {
            const container = document.getElementById('toast-container');
            if (!container) return;
            const toast = document.createElement('div');
            toast.className = `toast ${type}`;
            const icon = type === 'success' ? 'check-circle' : type === 'error' ? 'exclamation-circle' : 'info-circle';
            toast.innerHTML = `<i class="fas fa-${icon}"></i> ${message}`;
            container.appendChild(toast);
            setTimeout(() => toast.remove(), 4000);
        }
    </script>
</body>

</html>
